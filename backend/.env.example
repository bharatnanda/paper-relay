# LLM provider: openai or azure
LLM_PROVIDER=openai

# OpenAI configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Azure OpenAI / Azure AI Foundry OpenAI-compatible configuration
AZURE_OPENAI_API_KEY=
# Example: https://your-resource.openai.azure.com/openai/v1/
AZURE_OPENAI_BASE_URL=
# Azure uses the deployment name here
AZURE_OPENAI_MODEL=

# Magic Link Secret (required, generate a long random string)
MAGIC_LINK_SECRET=change-this-to-a-long-random-secret

# Optional SMTP overrides if you are not using the bundled Mailpit service
SMTP_HOST=
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
FROM_EMAIL=noreply@paperrelay.local
FRONTEND_URL=http://localhost:3000
